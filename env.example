# ==============================================
# LMS PROJECT ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains sensitive data

# ==============================================
# CORE DJANGO SETTINGS
# ==============================================

# Django Environment (development, staging, production)
DJANGO_ENV=development

# Django Secret Key (REQUIRED - Generate a new one for production)
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug Mode (True for development, False for production)
DEBUG=True

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# Database Host (REQUIRED for production)
AWS_DB_HOST=your-database-host.amazonaws.com

# Database Name
AWS_DB_NAME=postgres

# Database User
AWS_DB_USER=lms_admin

# Database Password (REQUIRED)
AWS_DB_PASSWORD=your-database-password

# Database Port
AWS_DB_PORT=5432

# ==============================================
# AWS S3 CONFIGURATION
# ==============================================

# AWS Access Key ID
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Bucket Name (REQUIRED for production)
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name

# S3 Region
AWS_S3_REGION_NAME=eu-west-2

# ==============================================
# EMAIL CONFIGURATION
# ==============================================

# Default From Email
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Outlook OAuth2 Configuration (Optional)
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_TENANT_ID=your-outlook-tenant-id
OUTLOOK_FROM_EMAIL=noreply@yourdomain.com

# ==============================================
# DOMAIN & URL CONFIGURATION
# ==============================================

# Primary Domain
PRIMARY_DOMAIN=localhost:8000

# Base URL (auto-constructed if not provided)
BASE_URL=http://localhost:8000

# ALB Domain (for production with load balancer)
ALB_DOMAIN=

# ==============================================
# SECURITY CONFIGURATION
# ==============================================

# Trusted IPs (comma-separated)
TRUSTED_IPS=127.0.0.1,localhost

# Default Trusted IPs (comma-separated)
DEFAULT_TRUSTED_IPS=127.0.0.1,localhost

# Additional Allowed Hosts (comma-separated)
ADDITIONAL_ALLOWED_HOSTS=

# Additional CORS Origins (comma-separated)
ADDITIONAL_CORS_ORIGINS=

# Additional CSRF Origins (comma-separated)
ADDITIONAL_CSRF_ORIGINS=

# ==============================================
# LOGGING CONFIGURATION
# ==============================================

# Logs Directory
LOGS_DIR=/home/ec2-user/lmslogs

# ==============================================
# STATIC & MEDIA FILES
# ==============================================

# Static Files Root
STATIC_ROOT=/home/ec2-user/lmsstaticfiles

# Media Root (for development only)
MEDIA_ROOT=/home/ec2-user/lms/media_local

# File Upload Temp Directory
FILE_UPLOAD_TEMP_DIR=/tmp

# ==============================================
# CACHE CONFIGURATION
# ==============================================

# Redis URL
REDIS_URL=redis://127.0.0.1:6379/1

# Cache Key Prefix
CACHE_KEY_PREFIX=lms_development_

# ==============================================
# AI INTEGRATION
# ==============================================

# Anthropic API Key (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Anthropic Model
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Anthropic Max Tokens
ANTHROPIC_MAX_TOKENS=1000

# ==============================================
# THIRD-PARTY INTEGRATIONS
# ==============================================

# Ideal Postcodes API Key (Optional)
IDEAL_POSTCODES_API_KEY=your-ideal-postcodes-api-key

# ==============================================
# TESTING CONFIGURATION
# ==============================================

# Test Password (for test cases)
TEST_PASSWORD=testpass123

# ==============================================
# PERFORMANCE CONFIGURATION
# ==============================================

# Memory Threshold (MB)
MEMORY_THRESHOLD_MB=800

# Memory Warning Threshold (MB)
MEMORY_WARNING_THRESHOLD_MB=600

# Dashboard Memory Threshold (MB)
DASHBOARD_MEMORY_THRESHOLD_MB=400

# Max Concurrent PDF Operations
MAX_CONCURRENT_PDF_OPERATIONS=2

# Dashboard Cache Timeout (seconds)
DASHBOARD_CACHE_TIMEOUT=300

# ==============================================
# SSL/SECURITY CONFIGURATION
# ==============================================

# Secure SSL Redirect (True for production with HTTPS)
SECURE_SSL_REDIRECT=False

# ==============================================
# NOTES
# ==============================================
# 1. Replace all placeholder values with your actual configuration
# 2. Never commit this file to version control
# 3. Use different values for development, staging, and production
# 4. Generate a new SECRET_KEY for each environment
# 5. Keep sensitive data secure and use proper access controls
